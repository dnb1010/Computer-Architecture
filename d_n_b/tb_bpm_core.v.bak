`timescale 1ns / 1ps

module tb_bpm_core;

    // 1. Khai b·o c·c tÌn hi?u Stimulus
    reg clk;
    reg rst;
    reg [9:0] signal_in; 

    // 2. Khai b·o c·c d‚y n?i (Wires)
    wire peak;
    wire [31:0] rr_interval;
    wire [31:0] rr_ms_out; 
    wire [7:0] bpm;
    wire abnormal;
    wire [1:0] arrhythmia_type; 
    
    // D‚y n?i cho sample_tick
    wire sample_tick_out;
    wire ready_strobe_u2;

    // =======================================================
    // B? CHIA T?N S?: T?o xung sample_tick 360Hz t? clk 50MHz
    // =======================================================
    // 50,000,000 / 360 = ~138,888 chu k? clock
    reg [17:0] tick_div;
    reg sample_tick_reg;
    assign sample_tick_out = sample_tick_reg;

    always @(posedge clk or posedge rst) begin
        if (rst) begin
            tick_div <= 0;
            sample_tick_reg <= 0;
        end else begin
            if (tick_div >= 18'd138887) begin
                tick_div <= 0;
                sample_tick_reg <= 1;
            end else begin
                tick_div <= tick_div + 1;
                sample_tick_reg <= 0;
            end
        end
    end

    // 3. Kh?i ph·t hi?n ??nh (u1)
    peak_detector u1 (
        .clk(clk),
        .rst(rst),
        .signal_in(signal_in),
        .threshold(10'd800), 
        .sample_tick(sample_tick_out), // ?„ c?p ngu?n 360Hz
        .peak(peak)
    );

    // 4. Kh?i ??m kho?ng c·ch RR (u2)
    rr_interval_counter u2 (
        .clk(clk),
        .rst(rst),
        .peak(peak),
        .rr_interval(rr_interval),
        .ready_strobe(ready_strobe_u2)
    );

    // 5. Kh?i tÌnh to·n BPM (u3)
    bpm_calculator u3 (
        .clk(clk),
        .rst(rst),
        .start_calc(peak),
        .rr_interval(rr_interval), 
        .rr_ms(rr_ms_out),             
        .bpm(bpm)
    );

    // 6. Kh?i c?nh b·o lo?n nh?p (u4)
    arrhythmia_detector u4 (
        .clk(clk),
        .rst(rst),
        .bpm(bpm),
        .ready_strobe(peak), 
        .abnormal(abnormal),
        .type(arrhythmia_type) 
    );

    // =======================================================
    // C?U HÃNH CLOCK & M‘ PH?NG
    // =======================================================
    
    // T?o xung clock 50MHz (Chu k? = 20ns)
    always #10 clk = ~clk;

    // Task mÙ ph?ng tÌn hi?u ECG (?„ ??ng b? v?i sample_tick 360Hz)
    task generate_clean_ecg;
        input integer interval_ticks; // TÌnh b?ng s? tick thay vÏ s? clock
        input integer beats;    
        integer i, j;           
    begin
        for (i = 0; i < beats; i = i + 1) begin
            for (j = 0; j < interval_ticks; j = j + 1) begin
                // QUAN TR?NG: ??i ?˙ng th?i ?i?m kh?i detector l?y m?u
                @(posedge sample_tick_out); 
                
                // T?o hÏnh d·ng "ng?n n˙i" ?? th?a m„n ?i?u ki?n (p2 > p1) && (p2 > p3)
                if (j == 0)      signal_in = 10'd600; // S??n lÍn
                else if (j == 1) signal_in = 10'd950; // ??NH
                else if (j == 2) signal_in = 10'd600; // S??n xu?ng
                else             signal_in = 10'd300; // M?c n?n
            end
        end
    end
    endtask

    // T? ??ng in ra Transcript m?i khi BPM thay ??i
    always @(bpm) begin
        if (bpm > 0) begin
            $display(">> [K?T QU?] Time: %0t | Nh?p tim tÌnh ???c: %d BPM | Abnormal: %b", $time, bpm, abnormal);
        end
    end

    // Qu· trÏnh ch?y Test
    initial begin
        // Kh?i t?o
        clk = 0;
        rst = 1;
        signal_in = 0;

        // Gi?i phÛng Reset
        #40 rst = 0;
        $display("-------------------------------------------");
        $display("--- BAT DAU MO PHONG HE THONG ECG ---");
        $display("-------------------------------------------");
        
        // TEST 1: Nh?p tim bÏnh th??ng (~75 BPM)
        // 75 BPM -> RR = 800ms. V?i 360Hz, 800ms t??ng ???ng kho?ng 288 ticks
        $display("\n==== TEST 1: NHIP BINH THUONG (Ky vong: ~75 BPM) ====");
        generate_clean_ecg(288, 4); 

        // TEST 2: Nh?p tim nhanh (~150 BPM)
        // 150 BPM -> RR = 400ms. T??ng ???ng 144 ticks
        $display("\n==== TEST 2: NHIP TIM NHANH (Ky vong: ~150 BPM) ====");
        generate_clean_ecg(144, 4); 

        // TEST 3: Nh?p tim ch?m (~40 BPM)
        // 40 BPM -> RR = 1500ms. T??ng ???ng 540 ticks
        $display("\n==== TEST 3: NHIP TIM CHAM (Ky vong: ~40 BPM) ====");
        generate_clean_ecg(540, 4); 

        #1000;
        $display("\n--- KET THUC MO PHONG ---");
        $finish;
    end

endmodule